SAP_ADT_BASE_URL=https://sap.example.com/sap/bc/adt
SAP_ADT_USERNAME=TECH_USER
SAP_ADT_PASSWORD=CHANGE_ME
SAP_ADT_TIMEOUT_MS=30000
SAP_ADT_VERIFY_TLS=true
# Optional fallback only. MCP first uses explicit transportRequest, then a single modifiable main request for the user.
SAP_ADT_DEFAULT_TRANSPORT_REQUEST=
SAP_ADT_ALLOWED_PACKAGES=Z*
SAP_ADT_ALLOWED_OBJECT_TYPES=class,program,ddls,dcls,ddlx
SAP_ADT_URI_TEMPLATES_FILE=./config/object-uri-templates.json
SAP_ADT_DEFAULT_MASTER_SYSTEM=A4H
SAP_ADT_DEFAULT_ABAP_LANGUAGE_VERSION=standard
SAP_ADT_DEFAULT_SOFTWARE_COMPONENT=HOME
SAP_ADT_DEFAULT_SOFTWARE_COMPONENT_DESCRIPTION=Customer Developments
